# ==============================================================================
# OS-spezifische Dateien (Verhindert Müll von Windows/Mac im Repository)
# ==============================================================================
Thumbs.db
Desktop.ini
.DS_Store

# ==============================================================================
# Python-Caches & Kompilate
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# ==============================================================================
# Virtuelle Umgebungen (Niemals die installierten Pakete hochladen!)
# ==============================================================================
.venv/
venv/
ENV/
env/

# ==============================================================================
# Test-Ergebnisse & Berichte (Pytest / Coverage)
# ==============================================================================
.coverage
htmlcov/
*.log
test-results/
reports/
junit/

# ==============================================================================
# Umgebungsvariablen & Passwörter (Sicherheit!)
# ==============================================================================
.env
.env.local
.env.*.local
*.secrets

# ==============================================================================
# IDE-spezifische Dateien (VS Code & PyCharm)
# ==============================================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
